{
  "name": "ai-base-app",
  "private": true,
  "scripts": {
    "// --- Infrastructure & Setup --- //": "",
    "k8s:init": "bash ./.k8s/scripts/setup-infra.sh",

    "// --- Deployment Pipeline --- //": "",
    "k8s:up:server": "bash ./.k8s/scripts/up-server.sh",
    "k8s:up:web": "bash ./.k8s/scripts/up-web.sh",

    "// --- Local Development & Utility --- //": "",
    "web:dev": "pnpm --filter=platform-admin-web dev",
    "gen:api": "pnpm --filter=platform-admin-web gen:api",
    "db:build": "pnpm --filter=@pkg/database build",
    "db:seed": "pnpm --filter=@pkg/database seed",
    "db:meta": "pnpm --filter=@pkg/database cache:build",

    "// --- Standard Tasks --- //": "",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint"
  },
  "devDependencies": {
    "turbo": "2.9.6",
    "typescript": "5.9.3"
  },
  "packageManager": "pnpm@9.15.9"
}
