{
  "name": "@pkg/ui",
  "version": "0.0.0",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./index.css": {
      "style": "./src/index.css",
      "default": "./src/index.css"
    },
    "./*": {
      "types": "./dist/*.d.ts",
      "import": "./dist/*.js",
      "require": "./dist/*.cjs"
    }
  },
  "scripts": {
    "build:source": "vite build",
    "build:tsc": "tsc --noEmit",
    "build:token": "tsx ./token-parser.js",
    "build": "pnpm build:token && pnpm build:source",
    "build:stg": "pnpm build",
    "build:prd": "pnpm build",
    "dev": "concurrently \"vite build --watch\" \"tsx ./token-parser.js --watch\"",
    "lint": "eslint . --fix && stylelint \"**/*.{css,scss}\" --fix",
    "storybook": "storybook dev -p 6006"
  },
  "peerDependencies": {
    "@base-ui/react": "1.3.0",
    "@dnd-kit/react": "0.3.2",
    "@tanstack/react-form": "1.28.5",
    "@tanstack/react-table": "8.21.3",
    "class-variance-authority": "0.7.1",
    "cmdk": "1.1.1",
    "date-fns": "4.1.0",
    "embla-carousel-react": "8.6.0",
    "input-otp": "1.4.2",
    "lodash-es": "4.17.23",
    "lucide-react": "1.14.0",
    "next-themes": "0.4.6",
    "radix-ui": "1.4.3",
    "react": "19.2.6",
    "react-day-picker": "9.14.0",
    "react-dom": "19.2.6",
    "react-resizable-panels": "4.8.0",
    "recharts": "3.8.0",
    "sonner": "2.0.7",
    "tw-animate-css": "1.4.0",
    "vaul": "1.1.2",
    "zod": "4.3.6"
  },
  "dependencies": {
    "clsx": "2.1.1",
    "tailwind-merge": "3.5.0"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "5.1.2",
    "@eslint/js": "10.0.1",
    "@fontsource-variable/geist": "5.2.8",
    "@pkg/config": "workspace:*",
    "@storybook/addon-a11y": "10.3.5",
    "@storybook/addon-docs": "10.3.5",
    "@storybook/addon-vitest": "10.3.5",
    "@storybook/react-vite": "10.3.5",
    "@tailwindcss/vite": "4.2.2",
    "@tokens-studio/sd-transforms": "2.0.3",
    "@types/node": "25.6.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.1",
    "@vitest/browser-playwright": "4.1.4",
    "@vitest/coverage-v8": "4.1.4",
    "concurrently": "9.2.1",
    "eslint": "10.2.0",
    "eslint-plugin-storybook": "10.3.5",
    "glob": "13.0.6",
    "globals": "17.5.0",
    "playwright": "1.59.1",
    "sd-tailwindcss-transformer": "2.2.1",
    "shadcn": "4.2.0",
    "storybook": "10.3.5",
    "style-dictionary": "5.4.0",
    "stylelint": "17.7.0",
    "tailwindcss": "4.2.2",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "vite": "8.0.11",
    "vite-plugin-dts": "4.5.4",
    "vite-plugin-lib-inject-css": "2.2.2",
    "vite-tsconfig-paths": "6.1.1",
    "vitest": "4.1.4"
  }
}
