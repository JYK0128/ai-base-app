{
  "name": "@pkg/database",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    },
    "./domains": {
      "types": "./dist/domains/index.d.ts",
      "import": "./dist/domains/index.js",
      "require": "./dist/domains/index.cjs",
      "default": "./dist/domains/index.js"
    },
    "./domains/*": {
      "types": "./dist/domains/*.d.ts",
      "import": "./dist/domains/*.js",
      "require": "./dist/domains/*.cjs",
      "default": "./dist/domains/*.js"
    }
  },
  "mikro-orm": {
    "preferTs": true,
    "tsLoader": "swc",
    "tsConfigPath": "./tsconfig.app.json",
    "configPaths": [
      "./src/mikro-orm.config.ts"
    ]
  },
  "scripts": {
    "dx": "dotenvx run --env=development --convention=nextjs --",
    "mo": "npm run dx -- mikro-orm",
    "predev": "npm run prebuild",
    "dev": "npm run dx -- bunchee --watch",
    "lint": "eslint .",
    "build": "bunchee --clean",
    "play": "vitest run src/test/play.test.ts",
    "migration:create": "npm run mo -- migration:create",
    "migration:up": "npm run mo -- migration:up",
    "migration:down": "npm run mo -- migration:down",
    "migration:list": "npm run mo -- migration:list",
    "migration:pending": "npm run mo -- migration:pending",
    "migration:blank": "npm run mo -- migration:create --blank",
    "seed": "npm run mo -- schema:fresh --run --seed",
    "prebuild": "npm run mo -- cache:generate --ts -c"
  },
  "dependencies": {
    "@mikro-orm/core": "7.0.10",
    "@mikro-orm/decorators": "7.0.10",
    "@mikro-orm/entity-generator": "7.0.10",
    "@mikro-orm/migrations": "7.0.10",
    "@mikro-orm/postgresql": "7.0.10",
    "@mikro-orm/reflection": "7.0.10",
    "@mikro-orm/seeder": "7.0.10",
    "@mikro-orm/sql-highlighter": "1.0.1",
    "@pkg/config": "workspace:*",
    "@swc/helpers": "0.5.21",
    "reflect-metadata": "0.2.2",
    "uuidv7": "1.2.1"
  },
  "devDependencies": {
    "@dotenvx/dotenvx": "1.61.0",
    "@mikro-orm/cli": "7.0.10",
    "@pkg/config": "workspace:*",
    "@swc-node/register": "1.11.1",
    "@swc/core": "1.15.24",
    "@types/node": "25.6.0",
    "bunchee": "6.10.0",
    "eslint": "9.39.4",
    "tsx": "4.21.0",
    "typescript": "6.0.2",
    "vitest": "4.1.4"
  }
}
