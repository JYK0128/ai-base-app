{
  "name": "@pkg/database",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "main": "./dist/index.ts",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    },
    "./domains": {
      "types": "./dist/domains.d.ts",
      "default": "./dist/domains.js"
    }
  },
  "mikro-orm": {
    "useTsNode": true,
    "configPaths": [
      "./src/mikro-orm.config.ts"
    ]
  },
  "scripts": {
    "mikro-orm": "npx mikro-orm",
    "dev": "bunchee --watch",
    "build": "bunchee --clean",
    "test": "pnpm run test:example",
    "test:integration": "vitest run src/test/example.test.ts",
    "test:temp": "vitest run src/temp.test.ts",
    "test:example": "vitest run src/test/example.test.ts"
  },
  "dependencies": {
    "@mikro-orm/core": "7.0.9",
    "@mikro-orm/decorators": "7.0.9",
    "@mikro-orm/entity-generator": "7.0.9",
    "@mikro-orm/migrations": "7.0.9",
    "@mikro-orm/postgresql": "7.0.9",
    "@mikro-orm/reflection": "7.0.9",
    "@mikro-orm/seeder": "7.0.9",
    "@mikro-orm/sql-highlighter": "1.0.1",
    "@pkg/config": "workspace:*",
    "reflect-metadata": "0.2.2"
  },
  "devDependencies": {
    "@mikro-orm/cli": "7.0.9",
    "@pkg/config": "workspace:*",
    "@types/node": "25.6.0",
    "@testcontainers/postgresql": "11.14.0",
    "bunchee": "6.10.0",
    "eslint": "9.39.4",
    "testcontainers": "11.14.0",
    "typescript": "6.0.2",
    "vitest": "4.1.4"
  }
}
