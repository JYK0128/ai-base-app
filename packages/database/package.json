{
  "name": "@pkg/database",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    },
    "./domains": {
      "types": "./dist/domains/index.d.ts",
      "import": "./dist/domains/index.js",
      "require": "./dist/domains/index.cjs",
      "default": "./dist/domains/index.js"
    },
    "./domains/*": {
      "types": "./dist/domains/*.d.ts",
      "import": "./dist/domains/*.js",
      "require": "./dist/domains/*.cjs",
      "default": "./dist/domains/*.js"
    }
  },
  "mikro-orm": {
    "useTsNode": true,
    "configPaths": [
      "./src/mikro-orm.config.ts"
    ]
  },
  "scripts": {
    "mikro-orm": "pnpm exec mikro-orm",
    "dev": "bunchee --watch",
    "build": "bunchee --clean",
    "build:lib": "tsc -p tsconfig.app.json",
    "test": "pnpm run test:example",
    "test:example": "vitest run src/test/example.test.ts",
    "migration:create": "pnpm exec mikro-orm migration:create --ts",
    "migration:create:blank": "pnpm exec mikro-orm migration:create --blank --ts",
    "migration:up": "pnpm exec mikro-orm migration:up",
    "migration:down": "pnpm exec mikro-orm migration:down",
    "migration:list": "pnpm exec mikro-orm migration:list",
    "migration:pending": "pnpm exec mikro-orm migration:pending",
    "seed": "pnpm exec mikro-orm seeder:run",
    "seed:reset": "pnpm exec mikro-orm schema:refresh --run",
    "prebuild": "dotenvx run --env=development --convention=nextjs -- mikro-orm cache:generate --ts --combined --config src/mikro-orm.config.ts"
  },
  "dependencies": {
    "@mikro-orm/core": "7.0.10",
    "@mikro-orm/decorators": "7.0.10",
    "@mikro-orm/entity-generator": "7.0.10",
    "@mikro-orm/migrations": "7.0.10",
    "@mikro-orm/postgresql": "7.0.10",
    "@mikro-orm/reflection": "7.0.10",
    "@mikro-orm/seeder": "7.0.10",
    "@mikro-orm/sql-highlighter": "1.0.1",
    "@pkg/config": "workspace:*",
    "@swc/helpers": "0.5.15",
    "reflect-metadata": "0.2.2"
  },
  "devDependencies": {
    "@dotenvx/dotenvx": "1.61.0",
    "@mikro-orm/cli": "7.0.10",
    "@pkg/config": "workspace:*",
    "@testcontainers/postgresql": "11.14.0",
    "@types/node": "25.6.0",
    "bunchee": "6.10.0",
    "eslint": "9.39.4",
    "testcontainers": "11.14.0",
    "typescript": "6.0.2",
    "vitest": "4.1.4"
  }
}
